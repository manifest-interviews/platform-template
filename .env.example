# Copy this file to .env for local development:
#   cp .env.example .env
#
# NOTE: the application reads these values directly from the environment and does
# not currently validate them at startup.

# Postgres connection string used by the app, migrations, and seed script.
DATABASE_URL=postgres://app:app@localhost:5432/platform_interview

# HTTP port the API listens on.
PORT=3000

# Node environment. Affects nothing critical yet.
NODE_ENV=development

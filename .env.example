# Copy this file to .env for local development:
#   cp .env.example .env
#
# All required values are validated at startup — the process exits with a clear
# error if one is missing or malformed.

# Postgres connection string used by the app, migrations, and seed script.
DATABASE_URL=postgres://app:app@localhost:5432/platform_interview

# Redis connection string (cache-aside for read-heavy endpoints).
REDIS_URL=redis://localhost:6379

# External payment processor base URL.
PAYMENT_PROCESSOR_URL=https://payment-processor.example.com

# Shared secret the payment processor sends (x-webhook-secret) to authenticate
# webhook callbacks.
PAYMENT_WEBHOOK_SECRET=dev-webhook-secret

# HTTP port the API listens on.
PORT=3000

# How often the background worker runs its reminder/reconciliation pass (ms).
WORKER_INTERVAL_MS=60000

# Node environment.
NODE_ENV=development
